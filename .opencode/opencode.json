{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": true,
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--chromeArg=--disable-blink-features=AutomationControlled"
      ]
    },
    "memento": {
      "type": "local",
      "enabled": true,
      "command": [
        "memento",
        "mcp",
        "--dir",
        "<YOUR_VAULT_PATH>"
      ]
    }
  }
}
